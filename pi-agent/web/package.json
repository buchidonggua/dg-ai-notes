{
  "name": "pi-agent-book",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "prebuild": "node scripts/check-counterpart.mjs",
    "check:sync": "node scripts/check-sync.mjs",
    "check:counterpart": "node scripts/check-counterpart.mjs",
    "build:pdf": "node scripts/build-pdf.mjs --variant=ts && node scripts/build-pdf.mjs --variant=python",
