    "build:pdf:python": "node scripts/build-pdf.mjs --variant=python"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.14",
    "@astrojs/react": "^4.2.7",
    "astro": "^5.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/mdast": "^4.0.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "gray-matter": "^4.0.3",
    "pdf-lib": "^1.17.1",
    "playwright": "^1.61.1",
    "typescript": "^5.9.3",
    "unist-util-visit": "^5.1.0"
  }
